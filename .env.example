# ============================================================
# FitTrack API — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# PostgreSQL credentials used by both the db container and the app
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ─── JWT ─────────────────────────────────────────────────────
# Base64-encoded secret key for signing JWT tokens (HMAC-SHA256)
# Generate one with: openssl rand -base64 32
JWT_SECRET=your_base64_encoded_secret_here

# ─── API Security ───────────────────────────────────────────
# A secret string that the mobile app sends in the X-App-Secret header.
# Requests without this header (or with the wrong value) are rejected with 403.
# This is defense-in-depth — it blocks casual curl/Postman abuse.
APP_SECRET=your_random_app_secret_here

# ─── Admin Dashboard ────────────────────────────────────────
# HTTP Basic Auth credentials for the browser-based admin dashboard at /admin/
# These are completely separate from JWT user authentication.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
